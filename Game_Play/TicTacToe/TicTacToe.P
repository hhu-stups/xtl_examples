:- use_module(library(avl)).
:- use_module(library(between)).
:- compile('../minimax_alpha_beta').

start(pos(max,E)) :- empty_avl(E).
 %, avl_store((2,2),E,max,E2), avl_store((1,3),E2,min,E3), avl_store((2,1),E3,max,E4), avl_store((2,3),E4,min,E5).
trans(A,P,P3) :- game_move(P,A,P2), normalise(P2,P3).
trans(auto_play(Depth,Value,Action),State,State2) :- player(State,Player),
   auto_play_for(Player),
   enum_depth(Depth),
   format('~nComputing Alpha-Beta Move for depth=~w and player=~w~n',[Depth,Player]),
   statistics(walltime,_),
   (minimax_value(State,Depth,Value,Action,State2)
    -> statistics(walltime,[_,Delta]),
       format('Move found in ~w ms: ~w, value=~w~n',[Delta,Action,Value])).
%trans(win,pos(P,B),pos(P,B)) :- win(B,_,max).
%trans(loose,pos(P,B),pos(P,B)) :- win(B,_,min).

auto_play_for(min).
auto_play_for(max).
%enum_depth(2).
enum_depth(9).

normalise(pos(P,B),pos(P,NB)) :- avl_to_list(B,L), ord_list_to_avl(L,NB).

:-if(1=2).
% normal game_value
player_worst_outcome_with_depth(P,_Depth,V) :- player_worst_outcome_wo_depth(P,V).
utility(P,_Depth,Val) :- heuristic_function_result(P,Val).
:-else.
% use the following lines to take distance to win/loss into account (slows down mini-max slightly)
player_worst_outcome_with_depth(P,Depth,W) :- player_worst_outcome_wo_depth(P,V), W is V*Depth.
utility(P,Depth,Val) :- 
   heuristic_function_result(P,HV),
   Val is HV*Depth. % the higher the remaining search depth, the better the win/loss
:- endif.

player_worst_outcome_wo_depth(max,X) :- X is -1.
player_worst_outcome_wo_depth(min,1).


game_move(pos(P,B),place(I,J,Piece),pos(OP,B2)) :- 
   other_player(P,Piece,OP), \+ win(B,_,OP),
   between(1,3,I), between(1,3,J),
   \+ avl_fetch((I,J),B,_),
   avl_store((I,J),B,P,B2).

player(pos(P,B),P).


% -----------------
  
other_player(max,cross,min).
other_player(min,circle,max).

prop(pos(P,B),'='('TO_MOVE',P)).
prop(pos(_,B),'='(board(I,J),P)) :- get_board(I,J,B,P).
prop(pos(_,B),'='('WINNER'(Reason),P)) :- win(B,Reason,P).
prop(P,'='('HEURISTIC',V)) :- heuristic_function_result(P,V).
%prop(pos(_,B),unsafe) :- win(B,_,max). %% Comment in for model checking; probably better to comment out auto_play as well

same_row(J,B,Player) :- between(1,3,J),
   avl_fetch((1,J),B,Player),  avl_fetch((2,J),B,Player), avl_fetch((3,J),B,Player).
same_col(I,B,Player) :- between(1,3,I),
   avl_fetch((I,1),B,Player),  avl_fetch((I,2),B,Player), avl_fetch((I,3),B,Player).

win(B,row(J),Player) :- same_row(J,B,Player).
win(B,col(I),Player) :- same_col(I,B,Player).
win(B,diagonal(D),Player) :- avl_fetch((2,2),B,Player),
       (D=1, avl_fetch((1,1),B,Player), avl_fetch((3,3),B,Player) ;
        D=2, avl_fetch((1,3),B,Player), avl_fetch((3,1),B,Player)).

get_board(I,J,B,Player) :- between(1,3,I), between(1,3,J),
   (avl_fetch((I,J),B,P) -> Player=P ; Player=empty).


heuristic_function_result(pos(_,B),Val) :- 
  (win(B,_,P) -> val(P,Val) ; Val=0).
val(min,X) :- X is -1.
val(max,1).
heuristic_function_active.

animation_function_result(pos(_,Board),Matrix2) :-
         findall(((I,J),Img),
             (get_board(I,J,Board,Value),
              animation_image(Value,Img,_)
              ),Matrix2).

animation_image_right_click_transition(I,J,place(I,J,_)).
animation_image_right_click_transition(I,J,auto_play(_,_,_)).

animation_image_click_transition(I,J,I,J,[place(I,J,_),auto_play(_,_,A)],4) :- dif(A,none).

animation_image(Nr,S) :- animation_image(_,Nr,S).
animation_image(empty,1,   'images/sm_empty_box.gif').
animation_image(max,2,   'images/sm_X.gif').
animation_image(min,3,   'images/sm_O.gif').
animation_image(drag,4,   'images/sm_gray_box.gif').


