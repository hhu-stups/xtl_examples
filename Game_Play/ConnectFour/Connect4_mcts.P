game_move(pos(Player,Board),place(I,J,Piece),pos(OP,B3)) :- 
   other_player(Player,Piece,OP),
   \+ is_winning_board(Board,_),
   between(1,7,I),
   find_free_slot(I,Board,1,J),
   board_store(I,J,Board,Player,B2),
   update_winner_after_move(B2,I,J,Player,B3).

% a variation which tries out moves in random order
random_game_move(pos(Player,Board),place(I,J,Piece),pos(OP,B3)) :- 
   other_player(Player,Piece,OP),
   \+ is_winning_board(Board,_),
   random_generate(I,[1,2,3,4,5,6,7]),
   find_free_slot(I,Board,1,J),
   board_store(I,J,Board,Player,B2),
   update_winner_after_move(B2,I,J,Player,B3).

:- use_module(library(random),[random_permutation/2, random_select/3]).
random_generate(I,List) :- random_select(El,List,Rest),!,
   (I=El ; random_generate(I,Rest)).

random_between(I) :-
   random_permutation([1,2,3,4,5,6,7],Perm),
   member(I,Perm).

find_free_slot(I,Board,J,Res) :- board_fetch(I,J,Board,_), !, % position already occupied
   J>1, % if J=1 the column is full
   Res is J-1.
find_free_slot(I,Board,J,Res) :- J<6, !, % we have not reached bottom yet
   J1 is J+1, find_free_slot(I,Board,J1,Res).
find_free_slot(_I,_Board,R,R). % we reached bottom

% get the player to move from the current state:
player(pos(Player,_Board),Player).

