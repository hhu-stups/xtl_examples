%trans(A,P,P3) :- my_random_game_move(P,A,P2), normalise(P2,P3).
trans(auto_play(Action),State,State2) :- player(State,Player),
   auto_play_for(Player),
   format('~nComputing MCTS Move for player=~w~n',[Player]),
   mcts_auto_play(State,5000,Action,State2),
   Action \= none.
trans(auto_play_minimax(Depth,Value,Action),State,State2) :- player(State,Player),
   enum_depth_for_minimax(Player,Depth),
   format('~nComputing Alpha-Beta Move for depth=~w and player=~w~n',[Depth,Player]),
   statistics(walltime,[W1,_]),
   minimax_auto_play(State,Depth,Value,Action,State2),
   Action \= none,
   statistics(walltime,[W2,_]), WTime is W2-W1,
   format('Alpha-Beta Move found in ~w ms: ~w~n',[WTime,Action]).
