% update winner info after a move
update_winner_after_move(Board,I,J,Player,NewBoard) :- check_player(Player),
   %print(check_win(I,J,Player)),nl, portray_board(Board),
   win_after_move(Board,I,J,Player,_Reason),!,
   % print(winner(I,J,Player,_Reason)),nl,
   board_store_winner(Board,Player,NewBoard).
update_winner_after_move(Board,_,_,_,Board).

check_player(min) :- !.
check_player(max) :- !.
check_player(X) :- print(unknown_player(X)),nl.


% check if there is a win for Player after putting a new piece at (I,J)
% under the assumption that there was no win before the piece was put there
win_after_move(Board,I,J,Player,col) :- J<4,
   J1 is J+1,
   board_fetch(I,J1,Board,Player),
   J2 is J1+1,
   board_fetch(I,J2,Board,Player),
   J3 is J2+1,
   board_fetch(I,J3,Board,Player).
win_after_move(Board,I,J,Player,Reason) :-
   offsets(Reason,Oi1,Oj1,Oi2,Oj2),
   count_same(I,J,Oi1,Oj1,Board,Player,0,CountRight),
   count_same(I,J,Oi2,Oj2,Board,Player,0,CountLeft),
   %print(count(Reason,Player,CountRight,CountLeft)),nl, print(Board),nl,
   CountRight+CountLeft+1 >= 4.

offsets(row,1,0,-1,0).
offsets(diagonal1,1,-1,-1,1).
offsets(diagonal2,1,1,-1,-1).

% count how many positions we find with same Player in some directions specified by the offsets
count_same(I,J,OffsetI,OffsetJ,Board,Player,Acc,Count) :-
   I1 is I + OffsetI,
   J1 is J + OffsetJ,
   board_fetch(I1,J1,Board,Player),!,
   Acc1 is Acc+1,
   count_same(I1,J1,OffsetI,OffsetJ,Board,Player,Acc1,Count).
count_same(_I,_J,_OffsetI,_OffsetJ,_Board,_Player,Acc,Acc).


