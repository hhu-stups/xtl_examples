% Board Management
% I between 1 and 7
% J between 1 and 6

:- if(1=2).
:- use_module(library(avl)).
empty_board(B) :- empty_avl(B).
normalise(pos(P,B),pos(P,NB)) :- avl_to_list(B,L), ord_list_to_avl(L,NB).

board_fetch(I,J,Board,Player) :- avl_fetch(bpos(I,J),Board,Player).
board_store(I,J,Board,Player,NewBoard) :- 
   avl_store(bpos(I,J),Board,Player,NewBoard).

board_store_winner(Board,Player,NewBoard) :- avl_store(winner,Board,Player,NewBoard).
board_get_winner(Board,Player) :- avl_fetch(winner,Board,Player).

portray_board(B) :- portray_avl(B).
:- else.
:- use_module(library(lists),[maplist/2,nth1/4]).
empty_board(board(C1,C2,C3,C4,C5,C6,C7,no_winner)) :- 
    maplist(empty_col,[C1,C2,C3,C4,C5,C6,C7]).
empty_col(col(e__,e__,e__,e__,e__,e__)).
normalise(A,A).
board_fetch(I,J,Board,Player) :- I<8,
    arg(I,Board,Col), arg(J,Col,Player), Player \= e__.
board_store(I,J,Board,Player,NewBoard) :- 
    arg_update(I,Board,Col,NewCol,NewBoard),
    arg_update(J,Col,_,Player,NewCol).
    
arg_update(I,Term,OldArg,NewArg,NewTerm) :-
    Term =.. [F|OldCols],
    nth1(I,OldCols,OldArg,RestCols),
    nth1(I,NewCols,NewArg,RestCols),
    NewTerm =.. [F|NewCols].

board_store_winner(board(C1,C2,C3,C4,C5,C6,C7,_),Player,
                   board(C1,C2,C3,C4,C5,C6,C7,Player)).

board_get_winner(Board,_) :-
    functor(Board,F,_), F \= board,!,
   add_error(connect4,'Illegal board: ',Board),fail.
board_get_winner(Board,Player) :-
    arg(8,Board,Player),
    Player \= no_winner.

portray_board1(B) :- print(B).
print_col(A) :- print(A),nl.
portray_board(B) :- 
    B =.. [_|Args], nl, maplist(print_col,Args).
:- endif.

is_winning_position(pos(_,Board),WinPlayer) :- !, is_winning_board(Board,WinPlayer).
is_winning_position(POS,_) :- add_error(connect4,'Illegal position: ',POS),fail.

is_winning_board(Board,WinPlayer) :- !, board_get_winner(Board,WinPlayer).

