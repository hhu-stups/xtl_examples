move_piece(king(_),I,J,_Board2,I2,J2) :-
   move_king(I,J,I2,J2).
move_piece(rook(_),I,J,Board2,I2,J2) :-
   move_rook(I,J,Board2,I2,J2).
move_piece(knight(_),I,J,_Board2,I2,J2) :-
   move_knight(I,J,I2,J2).
move_piece(bishop(_),I,J,Board2,I2,J2) :-
   move_bishop(I,J,Board2,I2,J2).
move_piece(queen(_),I,J,Board2,I2,J2) :-
   move_rook(I,J,Board2,I2,J2).
move_piece(queen(_),I,J,Board2,I2,J2) :-
   move_bishop(I,J,Board2,I2,J2).
move_piece(pawn(Col),I,J,Board2,I2,J2) :-
   move_pawn(Col,I,J,Board2,I2,J2).

% the moves of a king
move_king(I,J,I2,J2) :- move_king_hv(I,I2), move_king_hv(J,J2), (I,J) \= (I2,J2).

move_king_hv(I,I2) :- I>1, I2 is I-1.
move_king_hv(I,I).
move_king_hv(I,I2) :- I<8, I2 is I+1.


move_rook(I,J,Board,I2,J) :- I<8, I1 is I+1, move_hp(I1,J,Board,I2).
move_rook(I,J,Board,I2,J) :- I>1, I1 is I-1, move_hm(I1,J,Board,I2).
move_rook(I,J,Board,I,J2) :- J<8, J1 is J+1, move_vp(I,J1,Board,J2).
move_rook(I,J,Board,I,J2) :- J>1, J1 is J-1, move_vm(I,J1,Board,J2).

% move horizontal plus 1
move_hp(I,_J,_Board,I).
move_hp(I1,J,Board,IRes) :- I1<8,
   get_board(Board,I1,J,empty),
   I2 is I1+1, move_hp(I2,J,Board,IRes).
% move horizontal minus 1
move_hm(I,_J,_Board,I).
move_hm(I1,J,Board,IRes) :- I1>1,
   get_board(Board,I1,J,empty),
   I2 is I1-1, move_hm(I2,J,Board,IRes).

move_vp(_,J,_Board,J).
move_vp(I,J1,Board,JRes) :- J1<8,
   get_board(Board,I,J1,empty),
   J2 is J1+1, move_vp(I,J2,Board,JRes).
move_vm(_,J,_Board,J).
move_vm(I,J1,Board,JRes) :- J1>1,
   get_board(Board,I,J1,empty),
   J2 is J1-1, move_vm(I,J2,Board,JRes).
   
move_bishop(I,J,Board,IRes,JRes) :- (DI = 1 ; DI = -1), (DJ=1 ; DJ = -1),
   move_bish(I,DI,J,DJ,Board,IRes,JRes).

move_bish(I,DI,J,DJ,Board,IRes,JRes) :- 
   I1 is I+DI, I>0, I<9,
   J1 is J+DJ, J>0, J<9,
   (IRes=I1, JRes=J1
    ; get_board(Board,I1,J1,empty),
      move_bish(I1,DI,J1,DJ,Board,IRes,JRes)).


move_knight(I,J,I2,J2) :- move2(I,I2),move1(J,J2).
move_knight(I,J,I2,J2) :- move1(I,I2),move2(J,J2).

move2(I,I2) :- I>2, I2 is I-2.
move2(I,I2) :- I<7, I2 is I+2.
move1(I,I2) :- I>1, I2 is I-1.
move1(I,I2) :- I<8, I2 is I+1.

move_pawn(Col,I,J,Board2,I2,J2) :-
   (Col=black -> Delta is -1, J>1 ; Delta=1, J<8),
   % TO DO: pawn promotion
   move_pawn_aux(Col,Delta,I,J,Board2,I2,J2).

pawn_h_move1(black,J,J1) :- J>1, J1 is J-1.
pawn_h_move1(white,J,J1) :- J<8, J1 is J+1.

pawn_v_move1(I,I1) :- I>1, I1 is I-1.
pawn_v_move1(I,I1) :- I<8, I1 is I+1.

pawn_direction(black,-1).
pawn_direction(white,1).

pawn_origin_row(black,7).
pawn_origin_row(white,2).

move_pawn_aux(Col,Delta,I,J,Board,I,JRes) :-
   J1 is J+Delta,
   get_board(Board,I,J1,empty),
   (JRes = J1 
    ; pawn_origin_row(Col,J), % from the origin row we can also advance two squares
      JRes is J1+Delta,
      % TO DO: remember virtual pawn at I,J1 for en-passant in next move by other player
      get_board(Board,I,JRes,empty)).
move_pawn_aux(Col,Delta,I,J,Board,I1,J1) :-
   pawn_v_move1(I,I1),
   J1 is J+Delta,
   get_board(Board,I1,J1,Fig),
   get_colour(Fig,OtherCol),
   other_colour(Col,OtherCol).

