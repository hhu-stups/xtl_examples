% set the original chessboar initial position
set_start_position(P) :- empty_board(E),set_start_position(1,E,P).
set_start_position(9) -->
   set_dcg(1,1,rook(white)),   set_dcg(1,8,rook(black)),
   set_dcg(2,1,knight(white)), set_dcg(2,8,knight(black)),
   set_dcg(3,1,bishop(white)), set_dcg(3,8,bishop(black)),
   set_dcg(4,1,queen(white)),  set_dcg(4,8,queen(black)),
   set_dcg(5,1,king(white)),   set_dcg(5,8,king(black)),
   set_dcg(6,1,bishop(white)), set_dcg(6,8,bishop(black)),
   set_dcg(7,1,knight(white)), set_dcg(7,8,knight(black)),
   set_dcg(8,1,rook(white)),   set_dcg(8,8,rook(black)).
set_start_position(I) --> {I<9},
   set_dcg(I,2,pawn(white)),
   set_dcg(I,7,pawn(black)),
   {I1 is I+1},
   set_start_position(I1).
   
set_dcg(I,J,F,B,NB) :- set_board(B,I,J,F,NB).

% initial state for XTL
start(initialise).

% utility to setup valid position with Info fields
setup_position(Player,Board,pos(Player,Board,Info)) :-
   Info = info(WhiteKing,BlackKing),
   compute_king_positions(Board,WhiteKing,BlackKing).
compute_king_positions(Board,WhiteKing,BlackKing) :- WhiteKing=(I1,J1), BlackKing=(I2,J2),
   get_board_any(Board,I1,J1,king(white)),
   get_board_any(Board,I2,J2,king(black)).

% Transitions for XTL:
trans('SETUP_CHESS_BOARD',initialise,Pos) :-
  set_start_position(Board), setup_position(white,Board,Pos).
trans('PUZZLE'(Nr),initialise,Pos) :-
  empty_board(E), set_puzzle(Nr,Player,E,B), setup_position(Player,B,Pos).
trans('TEST'(Nr),initialise,Pos) :-
  test_position(Nr,Player,Board), setup_position(Player,Board,Pos).
trans(Trans,State,State2,[description(Desc)]) :- 
   move(State,Trans,State2),
   describe_move(Trans,Desc).
   %State=pos(Player,_,_),State2=pos(_,Board,_), \+ in_check(Board,Player).
:- if((\+ use_directed_mc(true) , \+ use_mcts_api(true))).
trans(auto_play(Depth,Value,Action),State,State2,[description(Desc)]) :-
   State = pos(Player,_,_),
   auto_play_for(Player),
   enum_depth(Depth),
   format('Computing Alpha-Beta Move for depth=~w~n',[Depth]),
   statistics(walltime,_),
   (value(State,Depth,Value,Action,State2)
    -> statistics(walltime,[_,Delta]),
       format('Move found in ~w ms: ~w, value=~w~n',[Delta,Action,Value])),
   describe_move(Action,Desc0),
   ajoin(['AUTO PLAY: ',Desc0],Desc).
:- endif.

% XTL State Properties:
prop(pos(P,_,_),'='(player_to_move,P)).
prop(State,Prop) :- State=pos(Colour,Board,_),
   in_check(Board,Colour),
   (move(State,_,_) -> Prop='CHECK_TO'(Colour) ; Prop = 'CHECK_MATE_TO'(Colour)).
prop(S,'='(utility,V)) :- utility(S,V).
prop(S,'='(heuristic,V)) :- heuristic_function_result(S,V).
prop(pos(_,_,Info),'='(king(C),(I,J))) :- get_king_from_info(C,Info,I,J).
prop(pos(_,Board,_),'='(Figure,(Colour,I,J))) :-
   between(1,8,I), between(1,8,J),
   get_board(Board,I,J,Piece),
   functor(Piece,Figure,_),
   get_colour(Piece,Colour),
   Piece \= empty.
prop(none(pos(Player,_,_)),'WINNER'(OP)) :- other_colour(Player,OP).

:- if(use_directed_mc(true)).
prop(Pos,unsafe) :- goal_position(Pos).

% define the following as target position
% one needs to setup the chess board and then refocus the animator and then use directed model checking
% https://www.adventofchess.com/year/2024/day/1
goal_position(pos(black,
 brd(brd(rook(white),pawn(white),empty,empty,empty,empty,pawn(black),rook(black)),
 brd(knight(white),pawn(white),empty,empty,empty,empty,pawn(black),knight(black)),
 brd(bishop(white),pawn(white),empty,empty,empty,empty,pawn(black),bishop(black)),
 brd(queen(white),pawn(white),empty,empty,pawn(black),empty,empty,empty),
 brd(empty,pawn(white),empty,empty,empty,empty,pawn(black),king(black)),
 brd(bishop(white),empty,pawn(white),empty,queen(black),empty,pawn(black),bishop(black)),
 brd(knight(white),pawn(white),king(white),empty,empty,empty,pawn(black),knight(black)),
 brd(rook(white),pawn(white),empty,empty,empty,empty,pawn(black),rook(black))),_)).

delta_to_goal(pos(Player,Board,_),Delta) :- goal_position(pos(Player2,Board2,_)),
   delta_between_pos(Board,Board2,Delta).

% compute difference between two positions; useful for directed model checking:
delta_between_pos(B1,B2,Delta) :- 
   functor(B1,brd,_), 
   functor(B2,brd,_), !,
   B1 =.. [brd|A1],
   B2 =.. [brd|A2],
   l_delta(A1,A2,Delta).
delta_between_pos(B,B,Delta) :- !, Delta=0.
delta_between_pos(_,_,1).

l_delta([],_,0).
l_delta([H|T],[H2|T2],Delta) :- delta_between_pos(H,H2,D1),
  l_delta(T,T2,D2), Delta is D1+D2.

% XTL Heuristic Function (for directed Model Checking, colouring state space visualizations,...)
heuristic_function_result(S,V) :- delta_to_goal(S,V). %utility(S,V).
:- else.
heuristic_function_result(S,V) :-  utility(S,V).
:- endif.
heuristic_function_active.

