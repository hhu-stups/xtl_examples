% not used for XTL; can be used to do auto play from command line: sicstus -l chess.P --goal "play."
play :- play(4).
play(D) :- start_play(SP), play(SP,D).
start_play(Pos) :- empty_board(E), set_puzzle(1,Player,E,B), setup_position(Player,B,Pos).

play(Position,Depth) :- 
   pretty_print(Position),
   print('THINKING'),nl,
   statistics(walltime,_),
   value(Position,Depth,Value,Action,NewBoard),
   statistics(walltime,[Tot,Delta]),
   format('Move = ~w, Value=~w, Time: ~w ms (~w ms since start) ~n',[Action,Value,Delta, Tot]),
   (Value > 250 -> print('WHITE WILL WIN'),nl
    ; Value < -250 -> print('BLACK WILL WIN'),nl
   ),
   (NewBoard=none(_) -> print('FINISHED'),nl
    ; play(NewBoard,Depth)
   ).


