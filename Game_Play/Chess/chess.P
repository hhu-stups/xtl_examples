xget_animation_image(king(Player),pos(Player,Board,Info),Mod,Img) :- % use red king if in check
    \+ king_not_in_check(Player,Board,Info),!,
    animation_image(king_in_check(Player),Mod,Img,_).
get_animation_image(Fig,_,Mod,Img) :- animation_image(Fig,Mod,Img,_).

animation_function_result(none(Pos),Matrix) :- !, 
   Pos = pos(Player,Board,Info), other_colour(Player,OP),
   animation_function_result(pos(OP,Board,Info),Matrix).
animation_function_result(pos(Player,Board,Info),Matrix) :- 
   (auto_play_for(Player)
    -> (Player = white -> Symb00 = '+' ; Symb00 = '-')
     ; (Player = white -> Symb00 = 'w' ; Symb00 = 'b')
    ),
   Matrix = [ ((0,0),Symb00), ((1,0),'8'), ((2,0),'7'), ((3,0),'6'), ((4,0),'5'),
              ((5,0),'4'), ((6,0),'3'), ((7,0),'2'), ((8,0),'1') | Matrix1],
   Matrix1 = [ ((0,1),' A '), ((0,2),' B '), ((0,3),' C '), ((0,4),' D '),
              ((0,5),' E '), ((0,6),' F '), ((0,7),' G '), ((0,8),' H ') | Matrix2],
   findall(((J,I),Img),
             (between(1,8,J), between(1,8,I), J8 is 9-J, get_board(Board,I,J8,Fig),
              Mod is (I+J) mod 2,
              get_animation_image(Fig,pos(Player,Board,Info),Mod,Img)
              ),Matrix2). %  , print(Matrix),nl.

animation_image_right_click_transition(0,0,TT) :- !, TT = auto_play(Depth,_,move(_,_,_,_,_,_)),
  (Depth=6 ; Depth=4 ; Depth = 3 ; Depth=2).
animation_image_right_click_transition(FromRow,FromCol,TransitionTemplate) :- 
   between(1,8,FromCol),  between(1,8,FromRow), 
   I = FromCol, J is 9-FromRow, % translate state viewer coordinates to chess coordinates
   TransitionTemplate = move(_Piece,I,J,_,_I2,_J2).
animation_image_click_transition(FromY,FromX,ToY,ToX,[TransitionTemplate,auto_play(_,_,A)],ImageNr) :-
   between(1,8,FromX),  between(1,8,FromY), 
   I = FromX, J is 9-FromY, I2 = ToX, J2 is 9-ToY,
   (Take=false, ImageNr = -1 ; dif(Take,false),ImageNr = -2),
   TransitionTemplate = move(_Piece,I,J,Take,I2,J2). %, dif(A,none(_)).

