% a simple heuristic to sum up the value of the pieces
heuristic(Board,H) :- findall(V, (get_board_any(Board,_,_,P), fig_value(P,V)), L),
  sumlist(L,H).

fig_value(king(C),Res) :- assign(C,1000,Res).
fig_value(queen(C),Res) :- assign(C,9,Res).
fig_value(rook(C),Res) :- assign(C,5,Res).
fig_value(bishop(C),Res) :- assign(C,3,Res).
fig_value(knight(C),Res) :- assign(C,3,Res).
fig_value(pawn(C),Res) :- assign(C,1,Res).
fig_value(empty,0).

assign(white,C,C).
assign(black,C,R) :- R is -(C).

other_colour(white,black).
other_colour(black,white).


empty_board(brd(E,E,E,E, E,E,E,E)) :- empty_brd(E).
empty_brd(brd(empty,empty,empty,empty,empty,empty,empty,empty)).


get_board_any(Board,I,J,Res) :- between(1,8,I), between(1,8,J),
  get_board(Board,I,J,Res).

get_board(Board,I,J,Res) :-
   arg(I,Board,BI),
   arg(J,BI,Res).

set_board(Board,I,J,NewEl,NewBoard) :-
   get_brd(I,Board,RowI),
   set_brd(J,RowI,NewEl,NewRowI),
   set_brd(I,Board,NewRowI,NewBoard).
  
get_brd(N,BRD,Res) :- arg(N,BRD,Res).

% setting rows or columns
set_brd(1,brd(_,C2,C3,C4,C5,C6,C7,C8),New,
          brd(New,C2,C3,C4,C5,C6,C7,C8)).
set_brd(2,brd(C1,_,C3,C4,C5,C6,C7,C8),New,
          brd(C1,New,C3,C4,C5,C6,C7,C8)).
set_brd(3,brd(C1,C2,_,C4,C5,C6,C7,C8),New,
          brd(C1,C2,New,C4,C5,C6,C7,C8)).
set_brd(4,brd(C1,C2,C3,_,C5,C6,C7,C8),New,
          brd(C1,C2,C3,New,C5,C6,C7,C8)).
set_brd(5,brd(C1,C2,C3,C4,_,C6,C7,C8),New,
          brd(C1,C2,C3,C4,New,C6,C7,C8)).
set_brd(6,brd(C1,C2,C3,C4,C5,_,C7,C8),New,
          brd(C1,C2,C3,C4,C5,New,C7,C8)).
set_brd(7,brd(C1,C2,C3,C4,C5,C6,_,C8),New,
          brd(C1,C2,C3,C4,C5,C6,New,C8)).
set_brd(8,brd(C1,C2,C3,C4,C5,C6,C7,_),New,
          brd(C1,C2,C3,C4,C5,C6,C7,New)).


get_colour(king(Col),Col).
get_colour(queen(Col),Col).
