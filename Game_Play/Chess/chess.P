% make a move and alternate player
move(pos(Colour,Board,Info),move(Piece,I,J,Take,I2,J2),pos(Other,NewBoard,Info2)) :- 
   move(Board,Piece,Colour,I,J,I2,J2,Take,NewBoard),
   update_kings_info(Piece,I2,J2,Info,Info2),
   king_not_in_check(Colour,NewBoard,Info2), 
   other_colour(Colour,Other).

describe_move(move(Piece,I,J,Take,I2,J2),DescMove) :-
   Piece =.. [P,Colour],
   ajoin(['Move ',Colour,' ',P,' from (',I,',',J,') to (',I2,',',J2,')'],DescMove0),
   (Take =.. [T,TColour]
    -> ajoin([DescMove0,' and take ',TColour,' ',T],DescMove)
     ; DescMove=DescMove0).
describe_move(_,'').

update_kings_info(king(black),I2,J2,info(KW,_),info(KW,(I2,J2))) :- !.
update_kings_info(king(white),I2,J2,info(_,KB),info((I2,J2),KB)) :- !.
update_kings_info(_,_,_,Info,Info).

moving_player_in_check(pos(Col,Board,Info)) :-
   get_king_from_info(Col,Info,I,J),
   in_check(Board,I,J,Col).

king_not_in_check(Colour,Board,Info) :-
    get_king_from_info(Colour,Info,I,J),
    \+ in_check(Board,I,J,Colour).

get_king_from_info(black,info(_,(I,J)),I,J).
get_king_from_info(white,info((I,J),_),I,J).

% true if a move takes a king
move_takes_king(move(_Piece,_I,_J,king(_),_I2,_J2)).


utility(pos(_,Board,_),H) :- heuristic(Board,H).

player(pos(P,_,_),P).

pretty_print(pos(_,Board,_)) :- between(1,8,Col),
   arg(Col,Board,Column),
   Column =.. [brd|Args],
   maplist(pp2,Args,PPArgs),
   format('~w: ~w~n',[Col,PPArgs]),fail.
pretty_print(pos(P,_,_)) :- format('TO MOVE: ~w~n',[P]).

pp2(Fig,Res) :- pp(Fig,PP), atom_concat(PP,' |',PP2), atom_concat(' ',PP2,Res).

