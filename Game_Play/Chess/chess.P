% ENCODING OF CHESS RULES
% for use with ProB - XTL mode
% Michael Leuschel, Dec. 2016 - 2024

% options
take_depth_into_account(true).
randomise_moves(true).
use_mcts_api(false).
use_directed_mc(false). % try and find goal_position

% comment out if you want auto_play moves to be computed for certain states only
%auto_play_for(_) :- fail.
auto_play_for(white).
%auto_play_for(black).

% comment out/in the Mini-Max depths that should be computed:
%enum_depth(2).
%enum_depth(3).
enum_depth(4).
%enum_depth(5).
%enum_depth(6).


% starting position for XTL
test_position(1,white,B) :-
   empty_board(E),
   set_board(E,3,3,king(white),B1),
   set_board(B1,8,8,king(black),B2),
   set_board(B2,1,1,rook(white),B3),
   set_board(B3,1,2,rook(white),B).
test_position(2,white,B) :-
   empty_board(E),
   set_board(E,3,3,king(white),B1),
   set_board(B1,8,8,king(black),B2),
   set_board(B2,1,1,queen(white),B3),
   set_board(B3,1,2,rook(white),B).
test_position(3,white,B) :- % Does work now: Patt is avoided by Mini-Max; but requires depth 6 (solving time 2 seconds)
   empty_board(E),
   set_board(E,3,3,king(white),B1),
   set_board(B1,8,8,king(black),B2),
   set_board(B2,1,1,rook(white),B3),
   set_board(B3,1,2,rook(white),B4),
   set_board(B4,8,6,knight(white),B).
test_position(4,white,B) :- % ditto: does work now, patt avoided, solution found with depth 4
   empty_board(E),
   set_board(E,4,6,knight(white),B1),
   set_board(B1,8,8,king(black),B2),
   set_board(B2,6,5,knight(white),B3),
   set_board(B3,5,5,knight(white),B4),
   set_board(B4,8,6,king(white),B).
test_position(5,white,B) :- % promotion check
   empty_board(E),
   set_board(E,3,3,king(white),B1),
   set_board(B1,8,8,king(black),B2),
   set_board(B2,1,7,pawn(white),B3),
   set_board(B3,2,6,pawn(white),B).
test_position(6,white,B) :- % promotion check
   empty_board(E),
   set_board(E,7,5,king(white),B1),
   set_board(B1,3,8,king(black),B2),
   set_board(B2,1,7,pawn(white),B3),
   set_board(B3,2,6,pawn(white),B).
test_position(7,black,B8) :- % https://www.adventofchess.com/year/2024/day/1
  set_start_position(Board), 
  set_board(Board,7,3,king(white),B1),
  set_board(B1,6,3,pawn(white),B2),
  set_board(B2,4,5,pawn(black),B3),
  set_board(B3,6,5,queen(black),B4),
  set_board(B4,5,1,empty,B5),
  set_board(B5,6,2,empty,B6),
  set_board(B6,4,8,empty,B7),
  set_board(B7,4,7,empty,B8).


