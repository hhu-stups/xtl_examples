% TO DO: store king position separately
in_check(Board,Colour) :-
   get_board_any(Board,I,J,king(Colour)),
   in_check(Board,I,J,Colour).
in_check(Board,I,J,Colour) :-
   other_colour(Colour,AttackingColour),
   is_attacked(Board,I,J,Colour,AttackingColour).

% is_attacked does moves in reverse; we could optimise this; e.g.,
% merge rook/bishop,king moves
is_attacked(Board,I,J,_,AttackingColour) :- move_rook(I,J,Board,I2,J2),
   get_board(Board,I2,J2,AttackingPiece),
   does_rook_moves(AttackingPiece,AttackingColour).
is_attacked(Board,I,J,_,AttackingColour) :- move_bishop(I,J,Board,I2,J2),
   get_board(Board,I2,J2,AttackingPiece),
   does_bishop_moves(AttackingPiece,AttackingColour).
is_attacked(Board,I,J,_,AttackingColour) :- move_knight(I,J,I2,J2),
   get_board(Board,I2,J2,AttackingPiece),
   AttackingPiece = knight(AttackingColour).
is_attacked(Board,I,J,_,AttackingColour) :- move_king(I,J,I2,J2),
   get_board(Board,I2,J2,AttackingPiece),
   AttackingPiece = king(AttackingColour).
is_attacked(Board,I,J,Colour,AttackingColour) :-
   pawn_h_move1(Colour,J,J2), % we move backwards from king to pawn
   pawn_v_move1(I,I2),
   get_board(Board,I2,J2,AttackingPiece),
   AttackingPiece = pawn(AttackingColour).

does_rook_moves(rook(Col),Col).
does_rook_moves(queen(Col),Col).

does_bishop_moves(bishop(Col),Col).
does_bishop_moves(queen(Col),Col).

% this captures simple moves, not en passant
move(Board,Piece,Colour,I,J,I2,J2,Take,NewBoard) :-
   between(1,8,I), between(1,8,J),
   get_board(Board,I,J,Piece),
   get_colour(Piece,Colour),
   set_board(Board,I,J,empty,Board2),
   move_piece(Piece,I,J,Board2,I2,J2),
   get_board(Board2,I2,J2,Piece2),
   (get_colour(Piece2,Col2)
      -> Col2 \= Colour,  % we cannot take a piece of our own colour
         Take = Piece2
       ; Take = false),
    check_for_promotion(Piece,J2,NewPiece),
    set_board(Board2,I2,J2,NewPiece,NewBoard).
move(Board,king(Colour),Colour,5,Row,3,Row,false,NewBoard) :-
    % TO DO: remember if king or castle moved 
    castling_row(Row,Colour),
    get_board(Board,2,Row,empty),
    get_board(Board,5,Row,king(Colour)),
    get_board(Board,1,Row,rook(Colour)),
    get_board(Board,3,Row,empty),
    get_board(Board,4,Row,empty),
    \+ in_check(Board,5,1,Colour),
    \+ in_check(Board,4,1,Colour),
    set_board(Board,1,Row,empty,B1),
    set_board(B1,5,Row,empty,B2),
    set_board(B2,4,Row,rook(Colour),B3),
    set_board(B3,3,Row,king(Colour),NewBoard).
move(Board,king(Colour),Colour,5,Row,7,Row,false,NewBoard) :- castling_row(Row,Colour),
    get_board(Board,6,Row,empty),
    get_board(Board,5,Row,king(Colour)),
    get_board(Board,8,Row,rook(Colour)),
    get_board(Board,7,Row,empty),
    \+ in_check(Board,5,1,Colour),
    \+ in_check(Board,6,1,Colour),
    set_board(Board,8,Row,empty,B1),
    set_board(B1,5,Row,empty,B2),
    set_board(B2,6,Row,rook(Colour),B3),
    set_board(B3,7,Row,king(Colour),NewBoard).

castling_row(1,white).
castling_row(8,black).

check_for_promotion(pawn(black),1,NewPiece) :- !, promoted_piece(black,NewPiece).
check_for_promotion(pawn(white),8,NewPiece) :- !, promoted_piece(white,NewPiece).
check_for_promotion(Piece,_,Piece).

promoted_piece(Col,queen(Col)).
promoted_piece(Col,knight(Col)).
promoted_piece(Col,rook(Col)).
